# ---- Perfil activo de Spring Boot ----
# Valores posibles: mysql-dev, sqlserver-dev, mysql-prod, sqlserver-prod
SPRING_PROFILES_ACTIVE=mysql-dev

# ---- MySQL (Desarrollo) ----
MYSQL_DEV_URL=jdbc:mysql://localhost:3306/products_react?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
MYSQL_DEV_USERNAME=root
MYSQL_DEV_PASSWORD=root

# ---- MySQL (Producción) ----
MYSQL_PROD_URL=jdbc:mysql://prod-host:3306/products_react
MYSQL_PROD_USERNAME=prod_user
MYSQL_PROD_PASSWORD=prod_password_secure

# ---- SQL Server (Desarrollo) ----
SQLSERVER_DEV_URL=jdbc:sqlserver://localhost:1433;databaseName=products_react;encrypt=false;trustServerCertificate=true
SQLSERVER_DEV_USERNAME=sa
SQLSERVER_DEV_PASSWORD=YourStrong!Passw0rd

# ---- SQL Server (Producción) ----
SQLSERVER_PROD_URL=jdbc:sqlserver://prod-host:1433;databaseName=products_react;encrypt=true;trustServerCertificate=false
SQLSERVER_PROD_USERNAME=prod_user
SQLSERVER_PROD_PASSWORD=prod_password_secure

# ---- JWT ----
# La clave debe ser una cadena Base64 de al menos 256 bits (32 bytes).
# Puede generarse con: openssl rand -base64 48
JWT_SECRET=Y2FtYmlhbWVfcG9yX3VuYV9jbGF2ZV9zZWd1cmFfZW5fcHJvZHVjY2lvbl9taW5pbW9fMjU2X2JpdHM=
JWT_EXPIRATION_MS=86400000

# ---- Servidor ----
SERVER_PORT=8080
